# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── Dọn dẹp trước khi nộp ──────────────────────────────────

# Script tạm (có thể chứa credentials)
docs/fetch_real_data.mjs

# Dữ liệu thật (chứa UUID / email người dùng thật)
docs/seed_real.sql

# Script Python tạo báo cáo (không thuộc source code)
*.py

# File tài liệu Word / Excel / PDF (nộp riêng nếu cần)
*.docx
*.xlsx
*.pdf

# File nén tạm
docs/*.zip
